DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Use DB_HOST=db when running inside Docker Compose; DB_HOST=localhost for local venv
DB_NAME=easybiz
DB_USER=easybiz
DB_PASSWORD=easybiz
DB_HOST=db
DB_PORT=5432

# Default admin credentials created on first docker compose up
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin

ENABLE_AI_MATCHING=false
ANTHROPIC_API_KEY=
